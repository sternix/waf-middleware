[package]
name = "waf-middleware"
version = "0.1.2"
edition = "2021"
description = "A high-performance Web Application Firewall (WAF) middleware for Rust web frameworks like Axum and Actix-web, powered by OWASP Core Rule Set patterns."
license = "MIT"
readme = "README.md"
authors = ["Samir Djelal <ssdjelal@gmail.com>"]
repository = "https://github.com/samirdjelal/waf-middleware"
homepage = "https://github.com/samirdjelal/waf-middleware"
documentation = "https://github.com/samirdjelal/waf-middleware/blob/main/README.md"
keywords = ["waf", "security", "firewall", "middleware", "rust"]

[dependencies]
axum = { version = "0.7", optional = true }
actix-web = { version = "4", optional = true }
tower = { version = "0.4", features = ["full"], optional = true }
fancy-regex = "0.13"
serde = { version = "1.0", features = ["derive"] }
serde_json = "1.0"
tracing = "0.1"
urlencoding = "2.1"
futures-util = "0.3"
bytes = "1.0"
pin-project-lite = "0.2"
http = "1.0"
once_cell = "1.19"

[build-dependencies]
regex = "1.10"

[features]
default = ["axum", "actix-web"]
axum = ["dep:axum", "dep:tower"]
actix-web = ["dep:actix-web"]
